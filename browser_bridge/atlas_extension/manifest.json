{
  "manifest_version": 3,
  "name": "FuckYouXcode Dictionary",
  "version": "0.2.0",
  "description": "Use the FuckYouXcode dictionary from the Atlas browser context menu.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "selection-overlay.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "FuckYouXcode Dictionary"
  }
}
